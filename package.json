{
  "name": "clawport",
  "version": "0.1.0",
  "description": "Universal porting tool for claw-ecosystem AI agent configurations",
  "bin": {
    "clawport": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "watcher": "tsx src/watcher/registry.ts"
  },
  "keywords": [
    "openclaw",
    "zeroclaw",
    "openfang",
    "ai-agent",
    "claw",
    "migration",
    "cli"
  ],
  "author": "Max Wang",
  "license": "MIT",
  "dependencies": {
    "@iarna/toml": "^3.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "glob": "^10.3.10",
    "js-yaml": "^4.1.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@iarna/toml": "^3.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18"
  }
}
